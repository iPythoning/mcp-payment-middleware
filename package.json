{
  "name": "mcp-payment-middleware",
  "version": "0.1.0",
  "description": "Add paid access to your MCP server in under 10 minutes. Free, open-source, MIT-licensed.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
