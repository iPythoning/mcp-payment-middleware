      "optional": false
    }
  },
  "dependencies": {
    "stripe": "^18.0.0"
  },
  "optionalDependencies": {
    "ethers": "^6.0.0"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.22.0",
    "typescript": "^5.0.0",
    "zod": "^3.24.0"
  }
