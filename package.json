    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "payment",
    "monetization",
    "x402",
    "usdc",
    "stripe",
    "middleware"
  ],
  "license": "MIT",
  "author": "iPythoning",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iPythoning/mcp-payment-middleware.git"
  },
  "peerDependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
